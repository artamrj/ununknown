# Image published by .github/workflows/ci.yml
UNUNKNOWN_IMAGE=ghcr.io/artamrj/ununknown
UNUNKNOWN_TAG=latest

# Keep this on loopback. The API is intentionally not safe for public exposure.
UNUNKNOWN_HOST=127.0.0.1
UNUNKNOWN_PORT=7331

# The container writes bind-mounted files as this host user/group.
# Run `id -u` and `id -g` on Linux if your IDs differ.
PUID=1000
PGID=1000

# Create these directories before the first `docker compose up`.
UNUNKNOWN_INPUT_PATH=./music
UNUNKNOWN_OUTPUT_PATH=./output
UNUNKNOWN_DATA_PATH=./data
RUST_LOG=info

# Optional provider credentials. Keep the real .env file out of Git.
UNUNKNOWN_ACOUSTID_KEY=
UNUNKNOWN_AUDD_TOKEN=
UNUNKNOWN_SPOTIFY_CLIENT_ID=
UNUNKNOWN_SPOTIFY_CLIENT_SECRET=
UNUNKNOWN_SOUNDCLOUD_CLIENT_ID=
UNUNKNOWN_SOUNDCLOUD_CLIENT_SECRET=
UNUNKNOWN_YOUTUBE_API_KEY=
UNUNKNOWN_DISCOGS_TOKEN=
UNUNKNOWN_LASTFM_KEY=
UNUNKNOWN_THEAUDIODB_KEY=
