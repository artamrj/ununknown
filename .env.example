# Image published by .github/workflows/release.yml from version tags.
UNUNKNOWN_IMAGE=ghcr.io/artamrj/ununknown
# Use a release version such as 0.6.0 for reproducible NAS deployments.
UNUNKNOWN_TAG=latest

# Keep this on loopback. The API is intentionally not safe for public exposure.
UNUNKNOWN_HOST=127.0.0.1
UNUNKNOWN_PORT=7331

# The entrypoint automatically assigns writable mounts to this host user/group,
# then drops root privileges before starting Ununknown.
# Run `id -u` and `id -g` on Linux to find the correct values.
PUID=1000
PGID=1000

# Docker creates missing output and data directories automatically. The input
# path should point to an existing music library because it is mounted read-only.
UNUNKNOWN_INPUT_PATH=./music
# Use rw only if Ununknown may delete originals after writing corrected output.
# Writable mode automatically prepares input directories for PUID:PGID.
UNUNKNOWN_INPUT_MODE=ro
UNUNKNOWN_OUTPUT_PATH=./output
# Existing music used only for duplicate detection. It is always mounted read-only.
UNUNKNOWN_REFERENCE_PATH=./reference
UNUNKNOWN_DATA_PATH=./data
RUST_LOG=info

# Optional provider credentials. Keep the real .env file out of Git.
UNUNKNOWN_ACOUSTID_KEY=
UNUNKNOWN_AUDD_TOKEN=
UNUNKNOWN_SPOTIFY_CLIENT_ID=
UNUNKNOWN_SPOTIFY_CLIENT_SECRET=
UNUNKNOWN_SOUNDCLOUD_CLIENT_ID=
UNUNKNOWN_SOUNDCLOUD_CLIENT_SECRET=
UNUNKNOWN_YOUTUBE_API_KEY=
UNUNKNOWN_DISCOGS_TOKEN=
UNUNKNOWN_LASTFM_KEY=
UNUNKNOWN_THEAUDIODB_KEY=
